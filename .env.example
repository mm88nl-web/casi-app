# ─── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Solana / CASI Escrow ───────────────────────────────────────────────
# Populated by `node scripts/sync-program-id.mjs` after `anchor deploy`.
# Leave as the System Program sentinel until you've deployed.
NEXT_PUBLIC_CASI_PROGRAM_ID=11111111111111111111111111111111

# The CASI treasury pubkey — must match `fee_wallet::ID` in programs/casi-escrow/src/lib.rs.
# Replace before approve_flash / settle_beam can succeed (else InvalidFeeWallet).
NEXT_PUBLIC_CASI_FEE_WALLET=11111111111111111111111111111111

# USDC mint addresses (defaults are Circle's devnet + mainnet mints).
NEXT_PUBLIC_USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Server-side RPC for /api/flashes/moderate tx verification.
# Set to your Helius or QuickNode URL for reliable dev verification;
# falls back to https://api.devnet.solana.com when unset.
HELIUS_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=
