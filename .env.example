# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Use sk_test_… locally, sk_live_… in Vercel Production scope only.
STRIPE_SECRET_KEY=
# Signing secret for the Connected-accounts webhook (payment_intent.*, charge.*).
STRIPE_WEBHOOK_SECRET=
# Signing secret for the Platform webhook (account.updated, account.application.deauthorized).
STRIPE_WEBHOOK_SECRET_PLATFORM=
# Must be https://www.casi.gg in production — the apex 307s and webhooks don't follow redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Solana / CASI Escrow ────────────────────────────────────────────────────
# Master kill-switch for the Solana Flash rail. Keep false until audited.
NEXT_PUBLIC_CASI_SOLANA_ENABLED=false
# Populated by `node scripts/sync-program-id.mjs` after `anchor deploy`.
NEXT_PUBLIC_CASI_PROGRAM_ID=11111111111111111111111111111111
# USDC mint addresses (Circle's devnet + mainnet mints).
NEXT_PUBLIC_USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Solana cluster shown in wallet adapter and explorer links (mainnet-beta / devnet).
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# NOTE: the var name is NEXT_PUBLIC_SOLANA_RPC — NOT NEXT_PUBLIC_SOLANA_RPC_URL.
# Set to your Helius / QuickNode endpoint; falls back to the public Solana RPC when unset.
NEXT_PUBLIC_SOLANA_RPC=
# Server-side RPC for on-chain tx verification in API routes.
HELIUS_RPC_URL=

# ─── Helius (Solana webhook provider) ────────────────────────────────────────
# API key + webhook ID used by src/lib/helius.ts to sync on-chain events.
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
# Authorization header value Helius sends with each webhook POST.
# Must match what's configured in the Helius dashboard.
HELIUS_WEBHOOK_SECRET=

# ─── Session-key delegation (Phase 3) ────────────────────────────────────────
# 32 raw bytes, base64 or hex. Generate: openssl rand -base64 32
# Rotating this value invalidates every installed delegate immediately.
DELEGATE_ENCRYPTION_KEY=
# 64-byte Solana keypair as base58 OR JSON array (same format as ~/.config/solana/id.json).
# Pays fees for delegated start_beam / settle_beam / flash instructions.
# Fund with ~0.05 SOL; keep balance monitored (cranker-monitor cron warns at 0.005 SOL).
SOLANA_CRANKER_KEYPAIR=

# ─── Cron authentication ─────────────────────────────────────────────────────
# Vercel passes this as Authorization: Bearer <secret> on scheduled cron invocations.
# Generate: openssl rand -base64 32
CRON_SECRET=

# ─── Cloudflare Turnstile (CAPTCHA) ──────────────────────────────────────────
# Gates signup / free-flash / abuse-report flows against bots.
# Get keys from https://dash.cloudflare.com → Turnstile → Add Site.
# If unset locally the widget renders nothing and server-side verifier short-circuits.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Observability (optional) ────────────────────────────────────────────────
# Slack / Discord / Better Stack incoming webhook URL.
# logError() fans out to this endpoint for WARN and ERROR level events.
ERROR_WEBHOOK_URL=
